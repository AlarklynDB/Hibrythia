---
import BaseLayout from '../layouts/BaseLayout.astro'
import CommunityHub from '../views/CommunityHub'
---

<BaseLayout
  title={'Community Hub | The Hibrythian Saga'}
  description={'A space for readers, worldbuilders, and fans of The Hibrythian Saga. Community discussions and comments.'}
  path={'/community'}
>
  <CommunityHub client:load />

  {/* Disqus Comments */}
  <div class="max-w-[960px] mx-auto px-6 pb-20">
    <div id="disqus_thread"></div>
    <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
  </div>

  <script>
    (function() {
      var disqus_config = function () {
        this.page.url = 'https://www.thehibrythiansaga.com/community';
        this.page.identifier = 'community-hub';
      };
      var d = document, s = d.createElement('script');
      s.src = 'https://the-hibrythian-saga.disqus.com/embed.js';
      s.setAttribute('data-timestamp', String(+new Date()));
      (d.head || d.body).appendChild(s);
    })();
  </script>
</BaseLayout>
